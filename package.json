{
  "name": "portfolio-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:sa": "sanity dev",
    "start": "astro dev",
    "prebuild": "$npm_execpath typegen && astro check",
    "build": "astro build",
    "deploy:sa": "sanity schema deploy --manifest-dir ./public/studio/static",
    "preview": "astro build && wrangler dev",
    "astro": "astro",
    "lint": "eslint --cache",
    "lint:fix": "eslint --fix --cache",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "typegen": "$npm_execpath typegen:sa && $npm_execpath typegen:cf",
    "typegen:cf": "wrangler types",
    "typegen:sa": "sanity schema extract && sanity typegen generate"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/hepta-slab": "^5.2.8",
    "@imikailoby/lastfm-ts": "2.0.3",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/astro": "^3.4.1",
    "@sanity/client": "^7.23.0",
    "@sanity/code-input": "^7.1.6",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "^6.1.0",
    "@sanity/visual-editing": "^5.4.4",
    "@shikijs/transformers": "^4.2.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tabler/icons-react": "3.44.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.0",
    "astro-compress": "^2.4.1",
    "astro-portabletext": "^0.13.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.21",
    "groq": "^6.1.0",
    "lodash": "^4.18.1",
    "partysocket": "^1.2.0",
    "posthog-js": "^1.392.0",
    "posthog-node": "^5.38.2",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.8.1",
    "remeda": "^2.39.0",
    "sanity": "^6.1.0",
    "sanity-plugin-webhooks-trigger": "^0.9.0",
    "sonner": "^2.0.7",
    "styled-components": "^6.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.9",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "partykit": "0.0.115",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-compiler-runtime": "19.1.0-rc.3",
    "react-is": "^19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.1",
    "wrangler": "^4.103.0"
  },
  "packageManager": "pnpm@11.8.0",
  "peerDependencies": {
    "react-compiler-runtime": "19.1.0-rc.3",
    "react-is": "^19.0.0"
  }
}
