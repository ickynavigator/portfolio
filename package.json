{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "test": " echo \"Warning: no test specified\"",
    "lint": "biome check",
    "lint:fix": "npm run lint --write",
    "typecheck": "tsc --noEmit",
    "checks": "npm run lint && npm run typecheck && npm run test",
    "typegen": "npm run typegen:extract && npm run typegen:generate && npm run typegen:lint",
    "typegen:extract": "sanity schema extract --enforce-required-fields --path ./sanity.schema.json",
    "typegen:generate": "sanity typegen generate",
    "typegen:lint": "biome check --write ./sanity.types.ts ./sanity.schema.json",
    "postinstall": "npm run typegen"
  },
  "dependencies": {
    "@mantine/core": "^7.10.1",
    "@mantine/hooks": "^7.10.1",
    "@next/bundle-analyzer": "^14.2.3",
    "@sanity/code-input": "^4.1.4",
    "@sanity/vision": "3",
    "@t3-oss/env-nextjs": "^0.10.1",
    "@tabler/icons-react": "^3.5.0",
    "@vercel/analytics": "^1.3.1",
    "@vercel/speed-insights": "^1.0.11",
    "next": "14.2.3",
    "next-sanity": "^9.3.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanity": "3",
    "styled-components": "6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8.4.38",
    "postcss-preset-mantine": "^1.15.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5"
  }
}