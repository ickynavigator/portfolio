---
import { IconDeviceDesktop, IconMoon, IconSun } from "@tabler/icons-astro";

import Toggle from "~/components/Toggle.astro";

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<theme-switcher class="no-js">
  <Toggle
    id={id}
    name="theme"
    class="supports-backdrop-filter:bg-muted/60"
    options={[
      { label: IconSun, value: "light" },
      { label: IconDeviceDesktop, value: "system" },
      { label: IconMoon, value: "dark" },
    ]}
  />
</theme-switcher>

<script>
  import { ThemeSwitcher } from "~/lib/theme.client";

  customElements.define("theme-switcher", ThemeSwitcher);
</script>
